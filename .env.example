# Appwrite — public, safe to bake into the client bundle at build time
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=YOUR_PROJECT_ID

# Build-time script vars — used by scripts/generate-audio.js only
# Set in CI secrets or locally in .env.local — never commit real values
# APPWRITE_API_KEY=          # Appwrite API key (server SDK — scripts + local testing)
# SARVAM_API_KEY=            # Sarvam AI API key (ASR + TTS)
# ELEVENLABS_API_KEY=        # ElevenLabs API key (TTS alternative)
