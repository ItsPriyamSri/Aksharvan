# Copy to .env.local and fill in — see docs/APPWRITE-SETUP.md

# Client (baked into Next.js bundle at build time)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=YOUR_PROJECT_ID

# Server / scripts only — never commit real values
# APPWRITE_API_KEY=          # Console → API Keys (databases + storage + functions scopes)
# SARVAM_API_KEY=            # Sarvam AI — generate-audio + asr-recognize function
# ELEVENLABS_API_KEY=        # ElevenLabs TTS fallback for generate-audio
