    },
    {
      "audioName": "cutscene_intro_01",
      "text": "नमस्ते! मैं टोटो हूँ। मैं अक्षरवन से आया हूँ।",
      "voice": "toto",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_intro_02a",
      "text": "हमारी दुनिया अक्षरवन से रंग और रोशनी गायब हो रहे हैं।",
      "voice": "toto",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_intro_02b",
      "text": "ओह नहीं! हमें कुछ करना होगा!",
      "voice": "tina",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_intro_03a",
      "text": "हमें तुम्हारी मदद चाहिए। क्या तुम हमारे साथ चलोगे?",
      "voice": "toto",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_intro_03b",
      "text": "क्या आप हमारी मदद करेंगे?",
      "voice": "tina",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_jungle_01",
      "text": "यह है जादूई जंगल। पहले यहाँ बहुत सारे रंग थे।",
      "voice": "tina",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_jungle_02",
      "text": "लेकिन अब सब कुछ धूसर हो गया है — न रंग, न पेड़, न जानवर।",
      "voice": "toto",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_jungle_03a",
      "text": "हमें आपकी मदद चाहिए इस जंगल में वापस से रंग भरने के लिए।",
      "voice": "toto",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_jungle_03b",
      "text": "हर सही जवाब के साथ जंगल में जान लौट आएगी। चलो शुरू करें!",
      "voice": "tina",
      "category": "cutscene"
    },
    {
      "audioName": "cutscene_complete_01",
      "text": "शाबाश! आपने जादूई जंगल को बचा लिया!",
      "voice": "tina",
      "category": "cutscene"
    },
    {
      "audioName": "story_hook_tina",
      "text": "जंगल को बचाने के लिए कुछ सवालों के जवाब दो!",
      "voice": "tina",
      "category": "cutscene"
    },
    {
      "audioName": "story_hook_toto",
      "text": "चलो सीखते हैं और जंगल को फिर से हरा-भरा बनाते हैं!",
      "voice": "toto",
      "category": "cutscene"
    }
  ]
